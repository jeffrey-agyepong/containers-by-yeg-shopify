---
import AboutStats from "@/components/about/AboutStats.astro";
import AboutFaq from "@/components/about/AboutFaq.astro";
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import ImageMod from "@/components/ImageMod.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const about = (await getEntry("about", "-index")) as CollectionEntry<"about">;

const {
  title,
  meta_title,
  description,
  image,
  about_us,
  faq_section_title,
  button,
  faq_section_subtitle,
  faqs,
} = about.data;
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <PageHeader title={title} />

  <!-- About Us sections -->
  <section id="about-content">
    <div class="cs-container">
      {about_us?.map((section, index) => (
        <div class={`cs-row ${index !== 0 ? "cs-row--divider" : ""} ${index % 2 !== 0 ? "cs-row--reverse" : ""}`}>
          <div class="cs-image-col">
            <div class="cs-picture-frame">
              <ImageMod
                class="cs-img"
                src={section?.image!}
                width={640}
                height={480}
                alt={section?.title}
              />
            </div>
          </div>
          <div class="cs-text-col">
            <span class="cs-topper">{index === 0 ? "Since 2006" : "What We Carry"}</span>
            <h2 class="cs-title">{section?.title}</h2>
            <div class="cs-body" set:html={markdownify(section?.content)} />
          </div>
        </div>
      ))}
    </div>
  </section>

  <AboutStats />

  <AboutFaq
    title={faq_section_title!}
    subtitle={faq_section_subtitle!}
    faqs={faqs!}
    buttonEnable={button?.enable}
    buttonLabel={button?.label}
    buttonLink={button?.link}
  />
</Base>

<style>
/*-- -------------------------- -->
<---        About Content       -->
<--- -------------------------- -*/

@media only screen and (min-width: 0rem) {
    #about-content {
        padding: var(--sectionPadding);
    }
    #about-content .cs-container {
        width: 100%;
        max-width: 80rem;
        margin: auto;
        display: flex;
        flex-direction: column;
        gap: clamp(3.5rem, 7vw, 5rem);
    }
    #about-content .cs-row {
        display: flex;
        flex-direction: column;
        gap: clamp(2.5rem, 5vw, 4rem);
    }
    #about-content .cs-row--divider {
        padding-top: clamp(3.5rem, 7vw, 5rem);
        border-top: 1px solid #e8e8e8;
    }
    #about-content .cs-image-col {
        width: 100%;
    }
    #about-content .cs-picture-frame {
        width: 100%;
        border-radius: 0.75rem;
        overflow: hidden;
        aspect-ratio: 4/3;
        position: relative;
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    }
    #about-content .cs-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    #about-content .cs-text-col {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }
    #about-content .cs-topper {
        color: var(--secondary);
    }
    #about-content .cs-title {
        margin: 0 0 1.25rem;
    }
    #about-content .cs-body {
        font-size: clamp(1rem, 1.5vw, 1.125rem);
        line-height: 1.7em;
        color: var(--bodyTextColor);
    }
}
@media only screen and (min-width: 64rem) {
    #about-content .cs-row {
        flex-direction: row;
        align-items: center;
    }
    #about-content .cs-row--reverse {
        flex-direction: row-reverse;
    }
    #about-content .cs-image-col {
        width: 48%;
        flex: none;
    }
    #about-content .cs-text-col {
        flex: 1;
    }
}
</style>
