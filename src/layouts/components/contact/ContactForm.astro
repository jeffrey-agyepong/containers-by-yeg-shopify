<!-- ============================================ -->
<!--               Contact Form                   -->
<!-- ============================================ -->

---
interface Props {
  action: string;
}
const { action } = Astro.props;
---

<section id="contact-form-section">
    <div class="cs-container">
        <div class="cs-form-wrapper">
            <div class="cs-form-header">
                <span class="cs-topper">Send a Message</span>
                <h2 class="cs-title">We would love to hear from you!</h2>
                <p class="cs-text">Fill out the form below and we'll get back to you as soon as possible. For bulk orders or pricing inquiries, please include as much detail as you can.</p>
            </div>
            <form class="cs-form" action={action} method="POST">
                <div class="cs-form-row">
                    <div class="cs-field-group">
                        <label class="cs-label" for="first-name">First Name <span class="cs-required">*</span></label>
                        <input class="cs-input" id="first-name" name="first_name" type="text" placeholder="John" required />
                    </div>
                    <div class="cs-field-group">
                        <label class="cs-label" for="last-name">Last Name</label>
                        <input class="cs-input" id="last-name" name="last_name" type="text" placeholder="Doe" />
                    </div>
                </div>
                <div class="cs-form-row">
                    <div class="cs-field-group">
                        <label class="cs-label" for="email">Email Address <span class="cs-required">*</span></label>
                        <input class="cs-input" id="email" name="email" type="email" placeholder="john@example.com" required />
                    </div>
                    <div class="cs-field-group">
                        <label class="cs-label" for="subject">Subject <span class="cs-required">*</span></label>
                        <input class="cs-input" id="subject" name="subject" type="text" placeholder="Bulk order inquiry" required />
                    </div>
                </div>
                <div class="cs-field-group cs-full">
                    <label class="cs-label" for="message">Message <span class="cs-required">*</span></label>
                    <textarea class="cs-input cs-textarea" id="message" name="message" rows="7" placeholder="Tell us about your order, product needs, or any questions..." required></textarea>
                </div>
                <div class="cs-form-footer">
                    <button type="submit" class="cs-button-solid">Send Message</button>
                </div>
            </form>
        </div>
    </div>
</section>

<style>
/*-- -------------------------- -->
<---        Contact Form        -->
<--- -------------------------- -*/

@media only screen and (min-width: 0rem) {
    #contact-form-section {
        padding: var(--sectionPadding);
    }
    #contact-form-section .cs-container {
        width: 100%;
        max-width: 80rem;
        margin: auto;
    }
    #contact-form-section .cs-form-wrapper {
        max-width: 56rem;
        margin: 0 auto;
        background-color: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 0.75rem;
        padding: clamp(2rem, 5vw, 3.5rem);
    }
    #contact-form-section .cs-form-header {
        text-align: center;
        margin-bottom: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    #contact-form-section .cs-topper {
        color: var(--secondary);
    }
    #contact-form-section .cs-title {
        margin: 0 0 0.75rem;
    }
    #contact-form-section .cs-text {
        font-size: clamp(1rem, 1.5vw, 1.0625rem);
        line-height: 1.6em;
        color: var(--bodyTextColor);
        margin: 0;
        max-width: 40rem;
    }
    #contact-form-section .cs-form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
    #contact-form-section .cs-form-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
    }
    #contact-form-section .cs-field-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    #contact-form-section .cs-full {
        width: 100%;
    }
    #contact-form-section .cs-label {
        font-size: 0.9375rem;
        font-weight: 600;
        line-height: 1.2em;
        color: var(--headerColor);
    }
    #contact-form-section .cs-required {
        color: #e53e3e;
    }
    #contact-form-section .cs-input {
        width: 100%;
        padding: 0.875rem 1rem;
        font-size: 1rem;
        line-height: 1.5em;
        color: var(--headerColor);
        background-color: #f7f8fa;
        border: 1px solid #e8e8e8;
        border-radius: 0.375rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
        font-family: inherit;
    }
    #contact-form-section .cs-input::placeholder {
        color: #aaa;
    }
    #contact-form-section .cs-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(255, 106, 62, 0.12);
    }
    #contact-form-section .cs-textarea {
        resize: vertical;
        min-height: 10rem;
    }
    #contact-form-section .cs-form-footer {
        display: flex;
        justify-content: flex-end;
        padding-top: 0.5rem;
    }
    #contact-form-section .cs-button-solid {
        font-size: 1rem;
        line-height: clamp(2.875rem, 5.5vw, 3.5rem);
        text-decoration: none;
        font-weight: 700;
        text-align: center;
        margin: 0;
        color: #fff;
        min-width: 10rem;
        padding: 0 2rem;
        background-color: var(--primary);
        border-radius: 0.25rem;
        border: none;
        display: inline-block;
        position: relative;
        z-index: 1;
        box-sizing: border-box;
        cursor: pointer;
        font-family: inherit;
    }
    #contact-form-section .cs-button-solid:before {
        content: "";
        position: absolute;
        height: 100%;
        width: 0%;
        background: #000;
        opacity: 0.25;
        top: 0;
        left: 0;
        z-index: -1;
        border-radius: 0.25rem;
        transition: width 0.3s;
    }
    #contact-form-section .cs-button-solid:hover:before {
        width: 100%;
    }
}
@media only screen and (min-width: 48rem) {
    #contact-form-section .cs-form-row {
        grid-template-columns: repeat(2, 1fr);
    }
}
</style>
